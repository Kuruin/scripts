//@version=6
indicator("Master Indicator", overlay=true)

// --- Input Parameters ---
showV20 = input.bool(true, title="Enable V20 Strategy", group="V20 Settings")
minPctMove = input.float(20.0, title="Minimum Movement (%)", step=1.0, group="V20 Settings")
trackYears = input.int(5, title="Track History (Years)", minval=1, maxval=10, step=1, group="V20 Settings")
bgBoxColor = input.color(color.new(color.green, 75), title="V20 Background Color", group="V20 Settings")
showRefLines = input.bool(true, title="Show V20 reference Lines", group="V20 Settings")
upperRefLineColor = input.color(color.new(color.red, 30), title="V20 Upper Ref Line Color", group="V20 Settings")
lowerRefLineColor = input.color(color.new(color.green, 30), title="V20 Lower Ref Line Color", group="V20 Settings")

// --- SMA Strategy Inputs ---
showSMA = input.bool(true, title="Enable SMA Strategy", group="SMA Strategy")
sma20Color = input.color(color.red, title="SMA 20 Color", group="SMA Strategy")
sma20Width = input.int(1, title="SMA 20 Width", minval=1, maxval=4, group="SMA Strategy")
sma50Color = input.color(color.green, title="SMA 50 Color", group="SMA Strategy")
sma50Width = input.int(1, title="SMA 50 Width", minval=1, maxval=4, group="SMA Strategy")
sma200Color = input.color(color.white, title="SMA 200 Color", group="SMA Strategy")
sma200Width = input.int(2, title="SMA 200 Width", minval=1, maxval=4, group="SMA Strategy")
showSMABgBox = input.bool(true, title="Show SMA Background", group="SMA Strategy")
smaBgBoxColor = input.color(color.new(color.green, 75), title="SMA Background Color", group="SMA Strategy")
showSMAAvgBgBox = input.bool(true, title="Show SMA Avg Background", group="SMA Strategy")
smaAvgBgBoxColor = input.color(color.new(color.yellow, 75), title="SMA Avg Background Color", group="SMA Strategy")
showSMASellDays = input.bool(true, title="Show Days Held on Sell", group="SMA Strategy")
showSMASellGain = input.bool(true, title="Show Gain % on Sell", group="SMA Strategy")

// --- Envelope Strategy Inputs ---
showEnv = input.bool(true, title="Enable Envelope Strategy", group="Envelope Strategy")
envLen = input.int(200, title="Length", minval=1, group="Envelope Strategy")
envPercent = input.float(14.0, title="Percent", step=1.0, group="Envelope Strategy")
envExponential = input.bool(false, title="Exponential", group="Envelope Strategy")
envBasisColor = input.color(#FF6D00, title="Basis Color", group="Envelope Strategy")
envBandColor = input.color(#2962FF, title="Band Color", group="Envelope Strategy")
envBgColor = input.color(color.rgb(33, 150, 243, 95), title="Background Color", group="Envelope Strategy")

// --- Strategy Logic ---
var float sequenceStartLow = na
var int greenCandleCount = 0
var bool signalFired = false

isGreen = close > open

if not isGreen
    // Reset trackers if it's not a green candle (i.e., red or doji)
    sequenceStartLow := na
    greenCandleCount := 0
    signalFired := false
else
    if greenCandleCount == 0
        // Record the low of the first green candle in the sequence
        sequenceStartLow := low
    greenCandleCount += 1

movePercent = 0.0
if greenCandleCount > 0 and not na(sequenceStartLow)
    // Calculate movement percentage from start low to current high
    movePercent := ((high - sequenceStartLow) / sequenceStartLow) * 100

// Time filter logic
msPerYear = 1000 * 60 * 60 * 24 * 365.25
isWithinTime = time >= (timenow - (trackYears * msPerYear))

// Condition: Currently green, reached min move, haven't fired yet, and within allowed history, and strategy is enabled
longCondition = showV20 and isGreen and (movePercent >= minPctMove) and not signalFired and isWithinTime

if longCondition
    signalFired := true

// --- Alerts ---
if longCondition
    alert("Buy Signal Triggered!", alert.freq_once_per_bar_close)

// --- Plotting ---
// Plot exactly above the high price level using absolute coordinates
if longCondition
    label.new(x=bar_index, y=high + (high * 0.02), text=str.tostring(movePercent, "#.##") + "%", style=label.style_label_down, color=#312d2d, textcolor=color.white)
    // Draw a translucent green background box over the entire valid sequence
    boxLeft = bar_index - (greenCandleCount - 1)
    boxTop = high + (high * 0.00) // Extend slightly above the highest point
    boxBottom = sequenceStartLow - (sequenceStartLow * 0.00) // Extend slightly below the start low
    box.new(left=boxLeft, top=boxTop, right=bar_index, bottom=boxBottom, bgcolor=bgBoxColor, border_color=na)
    // Draw horizontal lines extending to the price scale on the right
    if showRefLines
        line.new(x1=boxLeft, y1=high, x2=bar_index, y2=high, color=upperRefLineColor, style=line.style_dashed, width=1, extend=extend.right)
        line.new(x1=boxLeft, y1=sequenceStartLow, x2=bar_index, y2=sequenceStartLow, color=lowerRefLineColor, style=line.style_dashed, width=1, extend=extend.right)

// Keep track of the high and low of the most recently triggered signal to plot on the price scale
var float lastSignalHigh = na
var float lastSignalLow = na

if longCondition
    lastSignalHigh := high
    lastSignalLow := sequenceStartLow

// Use plot with trackprice=true to natively pin the latest values onto the right-hand price scale exactly like native indicator lines
plot(showV20 ? lastSignalHigh : na, title="Sequence High", color=showRefLines ? upperRefLineColor : na, trackprice=true, show_last=1, display=display.price_scale)
plot(showV20 ? lastSignalLow : na, title="Sequence Low", color=showRefLines ? lowerRefLineColor : na, trackprice=true, show_last=1, display=display.price_scale)

// --- SMA Strategy Logic & Plotting ---
sma20 = ta.sma(close, 20)
sma50 = ta.sma(close, 50)
sma200 = ta.sma(close, 200)

plot(showSMA ? sma20 : na, title="SMA 20", color=sma20Color, linewidth=sma20Width)
plot(showSMA ? sma50 : na, title="SMA 50", color=sma50Color, linewidth=sma50Width)
plot(showSMA ? sma200 : na, title="SMA 200", color=sma200Color, linewidth=sma200Width)

// --- SMA Position State ---
var string currentSMAPosition = "NONE" // Tracks whether we are currently "LONG" or "SHORT" or "NONE"
var float buyPrice = na
var int lastAvgLevel = 0 // Tracks how many 10% drops we've averaged on
var box currentSMABox = na
var float currentSMAHigh = na
var float currentSMALow = na
var box currentSMAAvgBox = na
var int buyTime = na

// SMA BUY Condition: 200 is at top, 50 is in middle, 20 is at bottom AND price closes below 20
smaAlignmentTrue = (sma200 > sma50) and (sma50 > sma20) and (close < sma20)
smaAlignmentJustCrossed = smaAlignmentTrue and not smaAlignmentTrue[1]

// We enter on the Open of the very next candle after the crossover candle, IF we aren't already long
smaBuyCondition = smaAlignmentJustCrossed[1] and currentSMAPosition != "LONG"

if showSMA and smaBuyCondition
    currentSMAPosition := "LONG"
    buyPrice := open
    buyTime := time
    lastAvgLevel := 0
    currentSMAHigh := high
    currentSMALow := low
    if showSMABgBox
        currentSMABox := box.new(left=bar_index, top=currentSMAHigh, right=bar_index, bottom=currentSMALow, bgcolor=smaBgBoxColor, border_color=na)
    currentSMAAvgBox := na
    alert("SMA Align Buy Signal Triggered!", alert.freq_once_per_bar_close)
    labelText = str.format("SMA Buy\n{0}", str.tostring(open, "#.##"))
    label.new(x=bar_index, y=low, text=labelText, style=label.style_label_up, color=color.rgb(53, 78, 24), textcolor=color.white)

if showSMA and currentSMAPosition == "LONG"
    currentSMAHigh := math.max(currentSMAHigh, high)
    currentSMALow := math.min(currentSMALow, low)
    if showSMABgBox and not na(currentSMABox)
        box.set_right(currentSMABox, bar_index)
        box.set_top(currentSMABox, currentSMAHigh)
        box.set_bottom(currentSMABox, currentSMALow)
    if showSMAAvgBgBox and not na(currentSMAAvgBox)
        box.set_right(currentSMAAvgBox, bar_index)

// --- Average Logic ---
// Track how far the price has fallen from the original buy price
fallPercent = currentSMAPosition == "LONG" and not na(buyPrice) ? ((buyPrice - low) / buyPrice) * 100 : 0.0
// We want to average every 10% drop (e.g., 10%, 20%, 30%, etc.)
currentAvgLevel = math.floor(fallPercent / 10)

// If we crossed a new 10% threshold, trigger an average signal
avgSignalCondition = currentSMAPosition == "LONG" and currentAvgLevel > lastAvgLevel and currentAvgLevel >= 1

if showSMA and avgSignalCondition
    lastAvgLevel := currentAvgLevel
    if showSMAAvgBgBox
        currentSMAAvgBox := box.new(left=bar_index, top=buyPrice, right=bar_index, bottom=low, bgcolor=smaAvgBgBoxColor, border_color=na)
    alert("SMA Average Signal Triggered!", alert.freq_once_per_bar_close)
    exactAvgPriceTarget = buyPrice * (1.0 - (currentAvgLevel * 0.10))
    labelAvgText = str.format("Avg {0}%\n{1}", str.tostring(currentAvgLevel * 10), str.tostring(exactAvgPriceTarget, "#.##"))
    label.new(x=bar_index, y=low - (low * 0.01), text=labelAvgText, style=label.style_label_up, color=color.rgb(139, 105, 41), textcolor=color.white)

// --- SMA Sell Condition ---
// 1. Original Rules: 200 is at bottom, 50 is in middle, 20 is at top AND price closes above 20
smaSellAlignmentTrue = (sma20 > sma50) and (sma50 > sma200) and (close > sma20)
smaSellAlignmentJustCrossed = smaSellAlignmentTrue and not smaSellAlignmentTrue[1]
// We enter on the Open of the very next candle after the crossover candle, IF we are currently long
smaSellCondition = smaSellAlignmentJustCrossed[1] and currentSMAPosition == "LONG"

if showSMA and smaSellCondition
    heldDays = not na(buyTime) ? math.floor((time - buyTime) / 86400000) : 0
    tradeGain = not na(buyPrice) ? ((open - buyPrice) / buyPrice) * 100 : 0.0
    currentSMAPosition := "NONE" // Reset to NONE
    buyPrice := na
    buyTime := na
    lastAvgLevel := 0
    alert("SMA Align Sell Signal Triggered!", alert.freq_once_per_bar_close)
    
    labelBaseText = str.format("SMA Sell\n{0}", str.tostring(open, "#.##"))
    labelDaysText = showSMASellDays ? str.format("\nDays: {0}", str.tostring(heldDays)) : ""
    labelGainText = showSMASellGain ? str.format("\nGain: {0}%", str.tostring(tradeGain, "#.##")) : ""
    
    labelSellText = labelBaseText + labelDaysText + labelGainText
    label.new(x=bar_index, y=high, text=labelSellText, style=label.style_label_down, color=color.rgb(180, 48, 48), textcolor=color.white)

// --- Envelope Strategy Logic & Plotting ---
envBasis = envExponential ? ta.ema(close, envLen) : ta.sma(close, envLen)
envK = envPercent / 100.0
envUpper = envBasis * (1 + envK)
envLower = envBasis * (1 - envK)

plot(showEnv ? envBasis : na, "Envelope Basis", color=envBasisColor)
envU = plot(showEnv ? envUpper : na, "Envelope Upper", color=envBandColor)
envL = plot(showEnv ? envLower : na, "Envelope Lower", color=envBandColor)
fill(envU, envL, color=showEnv ? envBgColor : na, title="Envelope Background")
