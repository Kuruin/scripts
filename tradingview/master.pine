//@version=6
//@description A comprehensive multi-indicator suite combining V20 volatility analysis, SMA alignment tracking, and dynamic Envelope plotting for robust trend following and momentum signals.

// ============================================================================
// MASTER INDICATOR - V20, SMA & ENVELOPE SUITE
// ============================================================================
// Author: Kuruin
// Version: 1.0
// Category: Trend Following / Momentum / Volatility
//
// DESCRIPTION:
// This script combines three powerful strategies into one seamless overlay:
// 1. V20 Strategy (Credit: Vivek Singhal Sir): Tracks short-term percentage moves from a defined low.
// 2. SMA Strategy (Credit: Vivek Singhal Sir): Multi-SMA alignment system with integrated averaging levels.
// 3. Envelope Strategy (Credit: Donika Mam): Dynamic band creation around an SMA or EMA basis.
//
// FEATURES:
// • Independent toggles for all three strategies
// • Dynamic background boxes framing active V20 and SMA sequences
// • Real-time tracking of holding days and percentage gains on exits
// • Clean, non-intrusive on-chart labels and reference lines
//
// HOW TO USE:
// 1. Apply to your chart (works well on Daily timeframe).
// 2. Enable or disable individual strategies based on your analysis style.
// 3. Customize baseline colors and reference bounds in the settings.
// 4. Look for the dynamic background boxes to highlight active trade sequences.
//
// ⚠️ DISCLAIMER:
// Past performance does not guarantee future results. This indicator is for 
// educational purposes only. Always conduct your own risk management.
// ============================================================================

indicator(title="Master Indicator - V20, SMA & Envelope v1.0", shorttitle="Master Indicator", overlay=true)

// --- Input Parameters ---
// Master Toggles
showV20 = input.bool(true, title="Enable V20 Strategy", group="Enable Strategies", tooltip="Toggles the entire V20 volatility tracking strategy on or off.")
showSMA = input.bool(true, title="Enable SMA Strategy", group="Enable Strategies", tooltip="Toggles the entire SMA alignment strategy on or off.")
showExtraSMA = input.bool(false, title="Enable Extra SMA", group="Enable Strategies", tooltip="Toggles the extra standalone Simple Moving Average on or off.")
showEnv = input.bool(true, title="Enable Envelope Strategy", group="Enable Strategies", tooltip="Toggles the Envelope indicator on or off.")

// --- V20 Strategy Inputs ---
minPctMove = input.float(20.0, title="Minimum Movement (%)", step=1.0, group="V20 Settings", tooltip="The minimum required percentage movement from the sequence start low to trigger a valid V20 buy signal.")
trackYears = input.int(5, title="Track History (Years)", minval=1, maxval=10, step=1, group="V20 Settings", tooltip="How many years back the strategy should look to validate a sequence.")
hideCompletedV20 = input.bool(true, title="Hide Completed V20 Trades", group="V20 Settings", tooltip="When enabled, V20 reference lines and boxes are automatically hidden once the price cycles down to touch the lower level and then back up to touch the upper level.")
bgBoxColor = input.color(color.new(color.green, 75), title="V20 Background Color", group="V20 Settings", tooltip="Color of the dynamic box drawn over an active V20 sequence.")
showRefLines = input.bool(true, title="Show V20 reference Lines", group="V20 Settings", tooltip="Toggles horizontal reference lines extending from the sequence high and low.")
refLineStyleStr = input.string("Solid", title="V20 Ref Line Style", options=["Solid", "Dashed", "Dotted"], group="V20 Settings", tooltip="Style of the V20 reference lines.")
refLineStyle = refLineStyleStr == "Solid" ? line.style_solid : refLineStyleStr == "Dashed" ? line.style_dashed : line.style_dotted
refLineWidth = input.int(2, title="V20 Ref Line Width", minval=1, maxval=4, group="V20 Settings", tooltip="Line thickness for the V20 reference lines.")
upperRefLineColor = input.color(color.new(color.red, 30), title="V20 Upper Ref Line Color", group="V20 Settings", tooltip="Color of the upper reference line and price scale label.")
lowerRefLineColor = input.color(color.new(color.green, 30), title="V20 Lower Ref Line Color", group="V20 Settings", tooltip="Color of the lower reference line and price scale label.")

// --- SMA Strategy Inputs ---
sma20Color = input.color(color.red, title="SMA 20 Color", group="SMA Strategy", tooltip="Color for the 20-period Simple Moving Average.")
sma20Width = input.int(1, title="SMA 20 Width", minval=1, maxval=4, group="SMA Strategy", tooltip="Line thickness for the SMA 20.")
sma50Color = input.color(color.green, title="SMA 50 Color", group="SMA Strategy", tooltip="Color for the 50-period Simple Moving Average.")
sma50Width = input.int(1, title="SMA 50 Width", minval=1, maxval=4, group="SMA Strategy", tooltip="Line thickness for the SMA 50.")
sma200Color = input.color(color.white, title="SMA 200 Color", group="SMA Strategy", tooltip="Color for the 200-period Simple Moving Average.")
sma200Width = input.int(2, title="SMA 200 Width", minval=1, maxval=4, group="SMA Strategy", tooltip="Line thickness for the SMA 200.")

// --- Extra SMA Inputs ---
extraSMALength = input.int(300, title="Extra SMA Length", minval=1, group="Extra SMA Settings", tooltip="Lookback period for the extra standalone Simple Moving Average.")
extraSMAColor = input.color(color.yellow, title="Extra SMA Color", group="Extra SMA Settings", tooltip="Color for the extra standalone Simple Moving Average.")
extraSMAWidth = input.int(1, title="Extra SMA Width", minval=1, maxval=4, group="Extra SMA Settings", tooltip="Line thickness for the extra standalone SMA.")

showSMABgBox = input.bool(true, title="Show SMA Background", group="SMA Strategy", tooltip="Draws a dynamic background box highlighting the bounds of an active SMA sequence.")
smaBgBoxColor = input.color(color.new(color.green, 75), title="SMA Background Color", group="SMA Strategy", tooltip="Color of the dynamic background box for the main SMA entry.")
showSMAAvgBgBox = input.bool(true, title="Show SMA Avg Background", group="SMA Strategy", tooltip="Draws a background box down to the low of candles that trigger SMA Average Signals.")
smaAvgBgBoxColor = input.color(color.new(color.yellow, 75), title="SMA Avg Background Color", group="SMA Strategy", tooltip="Color of the background box for SMA Average signals.")
showSMASellDays = input.bool(true, title="Show Days Held on Sell", group="SMA Strategy", tooltip="Displays the number of calendar days a position was held inside the Sell label.")
showSMASellGain = input.bool(true, title="Show Gain % on Sell", group="SMA Strategy", tooltip="Calculates and displays the percentage gain or loss inside the Sell label.")

// --- Envelope Strategy Inputs ---
envLen = input.int(200, title="Length", minval=1, group="Envelope Strategy", tooltip="The lookback period length for the Envelope moving average basis.")
envPercent = input.float(14.0, title="Percent", step=1.0, group="Envelope Strategy", tooltip="The percentage threshold used to calculate the upper and lower Envelope bands from the basis.")
envExponential = input.bool(false, title="Exponential", group="Envelope Strategy", tooltip="If true, uses an EMA for the baseline instead of an SMA.")
envBasisColor = input.color(#FF6D00, title="Basis Color", group="Envelope Strategy", tooltip="Color of the central Envelope baseline.")
envBandColor = input.color(#2962FF, title="Band Color", group="Envelope Strategy", tooltip="Color of the upper and lower Envelope bands.")
envBgColor = input.color(color.rgb(33, 150, 243, 95), title="Background Color", group="Envelope Strategy", tooltip="Color to fill the background space between the upper and lower bands.")

// --- Strategy Logic ---
var float sequenceStartLow = na
var int greenCandleCount = 0
var bool signalFired = false

isGreen = close > open

if not isGreen
    // Reset trackers if it's not a green candle (i.e., red or doji)
    sequenceStartLow := na
    greenCandleCount := 0
    signalFired := false
else
    if greenCandleCount == 0
        // Record the low of the first green candle in the sequence
        sequenceStartLow := low
    else if low < sequenceStartLow
        sequenceStartLow := low
    greenCandleCount += 1

movePercent = 0.0
if greenCandleCount > 0 and not na(sequenceStartLow)
    // Calculate movement percentage from start low to current high
    movePercent := ((high - sequenceStartLow) / sequenceStartLow) * 100

// Time filter logic
msPerYear = 1000 * 60 * 60 * 24 * 365.25
isWithinTime = time >= (timenow - (trackYears * msPerYear))

// Condition: Currently green, reached min move, haven't fired yet, and within allowed history, and strategy is enabled
longCondition = showV20 and isGreen and (movePercent >= minPctMove) and not signalFired and isWithinTime

if longCondition
    signalFired := true

// --- Alerts ---
if longCondition
    alert("Buy Signal Triggered!", alert.freq_once_per_bar_close)

// --- V20 Trade Tracking Types ---
type V20Trade
    box bgBox
    label pctLabel
    line upperLine
    line lowerLine
    float tradeHigh
    float tradeLow
    int state // 0: Active, 1: Touched Lower exactly or below
    int startBar

var v20Trades = array.new<V20Trade>()

// --- Plotting ---
// Plot exactly above the high price level using absolute coordinates
if longCondition
    // Draw a translucent green background box over the entire valid sequence
    boxLeft = bar_index - (greenCandleCount - 1)
    boxTop = high + (high * 0.00) // Extend slightly above the highest point
    boxBottom = sequenceStartLow - (sequenceStartLow * 0.00) // Extend slightly below the start low
    
    newLabel = label.new(x=bar_index, y=high + (high * 0.02), text=str.tostring(movePercent, "#.##") + "%", style=label.style_label_down, color=#312d2d, textcolor=color.white)
    newBox = box.new(left=boxLeft, top=boxTop, right=bar_index, bottom=boxBottom, bgcolor=bgBoxColor, border_color=na)
    
    line lineUpper = na
    line lineLower = na

    if showRefLines
        lineUpper := line.new(x1=boxLeft, y1=high, x2=bar_index, y2=high, color=upperRefLineColor, style=refLineStyle, width=refLineWidth, extend=extend.right)
        lineLower := line.new(x1=boxLeft, y1=sequenceStartLow, x2=bar_index, y2=sequenceStartLow, color=lowerRefLineColor, style=refLineStyle, width=refLineWidth, extend=extend.right)

    newTrade = V20Trade.new(newBox, newLabel, lineUpper, lineLower, high, sequenceStartLow, 0, bar_index)
    array.push(v20Trades, newTrade)
else if signalFired and isGreen and array.size(v20Trades) > 0
    trade = array.get(v20Trades, array.size(v20Trades) - 1)
    if bar_index >= trade.startBar and (bar_index - trade.startBar) <= greenCandleCount
        if low < trade.tradeLow
            trade.tradeLow := low
            box.set_bottom(trade.bgBox, low)
            if not na(trade.lowerLine)
                line.set_y1(trade.lowerLine, low)
                line.set_y2(trade.lowerLine, low)
                
        if high > trade.tradeHigh
            trade.tradeHigh := high
            box.set_top(trade.bgBox, high)
            if not na(trade.upperLine)
                line.set_y1(trade.upperLine, high)
                line.set_y2(trade.upperLine, high)
                
        currentMovePercent = ((trade.tradeHigh - trade.tradeLow) / trade.tradeLow) * 100
        label.set_y(trade.pctLabel, trade.tradeHigh + (trade.tradeHigh * 0.02))
        label.set_text(trade.pctLabel, str.tostring(currentMovePercent, "#.##") + "%")
        
        box.set_right(trade.bgBox, bar_index)
        label.set_x(trade.pctLabel, bar_index)
        if not na(trade.upperLine)
            line.set_x2(trade.upperLine, bar_index)
        if not na(trade.lowerLine)
            line.set_x2(trade.lowerLine, bar_index)

// Evaluate range completion logic (Price touches lower exactly or below, then upper exactly or above)
if array.size(v20Trades) > 0
    for i = array.size(v20Trades) - 1 to 0
        trade = array.get(v20Trades, i)
        
        // Ensure we don't complete on the very candle that triggered it
        if bar_index > trade.startBar
            touchedLowerNow = low <= trade.tradeLow
            touchedUpperNow = high >= trade.tradeHigh
            
            if trade.state == 0
                if touchedLowerNow
                    trade.state := 1
                    // Prevent same-bar immediate completion on red candles that hit high first then drop.
                    if touchedUpperNow and close >= open
                        trade.state := 2
            else if trade.state == 1
                if touchedUpperNow
                    trade.state := 2
            
        if trade.state == 2 and hideCompletedV20
            // Trade complete: remove all indicators
            box.delete(trade.bgBox)
            label.delete(trade.pctLabel)
            if not na(trade.upperLine)
                line.delete(trade.upperLine)
            if not na(trade.lowerLine)
                line.delete(trade.lowerLine)
            array.remove(v20Trades, i)

// Use plot with trackprice=true to natively pin the latest values onto the right-hand price scale exactly like native indicator lines
// Plot the most recent active trade's bounds
float currentScaleHigh = na
float currentScaleLow = na
if array.size(v20Trades) > 0
    lastActive = array.get(v20Trades, array.size(v20Trades) - 1)
    currentScaleHigh := lastActive.tradeHigh
    currentScaleLow := lastActive.tradeLow

plot(showV20 ? currentScaleHigh : na, title="Sequence High", color=showRefLines ? upperRefLineColor : na, trackprice=true, show_last=1, display=display.price_scale)
plot(showV20 ? currentScaleLow : na, title="Sequence Low", color=showRefLines ? lowerRefLineColor : na, trackprice=true, show_last=1, display=display.price_scale)

// --- SMA Strategy Logic & Plotting ---
sma20 = ta.sma(close, 20)
sma50 = ta.sma(close, 50)
sma200 = ta.sma(close, 200)

plot(showSMA ? sma20 : na, title="SMA 20", color=sma20Color, linewidth=sma20Width)
plot(showSMA ? sma50 : na, title="SMA 50", color=sma50Color, linewidth=sma50Width)
plot(showSMA ? sma200 : na, title="SMA 200", color=sma200Color, linewidth=sma200Width)

// --- Extra SMA Logic & Plotting ---
extraSMA = ta.sma(close, extraSMALength)
plot(showExtraSMA ? extraSMA : na, title="Extra SMA", color=extraSMAColor, linewidth=extraSMAWidth)

// --- SMA Position State ---
var string currentSMAPosition = "NONE" // Tracks whether we are currently "LONG" or "SHORT" or "NONE"
var float buyPrice = na
var int lastAvgLevel = 0 // Tracks how many 10% drops we've averaged on
var box currentSMABox = na
var float currentSMAHigh = na
var float currentSMALow = na
var box currentSMAAvgBox = na
var int buyTime = na

// SMA BUY Condition: 200 is at top, 50 is in middle, 20 is at bottom AND price closes below 20
smaAlignmentTrue = (sma200 > sma50) and (sma50 > sma20) and (close < sma20)
smaAlignmentJustCrossed = smaAlignmentTrue and not smaAlignmentTrue[1]

// We enter on the Open of the very next candle after the crossover candle, IF we aren't already long
smaBuyCondition = smaAlignmentJustCrossed[1] and currentSMAPosition != "LONG"

if showSMA and smaBuyCondition
    currentSMAPosition := "LONG"
    buyPrice := open
    buyTime := time
    lastAvgLevel := 0
    currentSMAHigh := high
    currentSMALow := low
    if showSMABgBox
        currentSMABox := box.new(left=bar_index, top=currentSMAHigh, right=bar_index, bottom=currentSMALow, bgcolor=smaBgBoxColor, border_color=na)
    currentSMAAvgBox := na
    alert("SMA Align Buy Signal Triggered!", alert.freq_once_per_bar_close)
    labelText = str.format("SMA Buy\n{0}", str.tostring(open, "#.##"))
    label.new(x=bar_index, y=low, text=labelText, style=label.style_label_up, color=color.rgb(53, 78, 24), textcolor=color.white)

if showSMA and currentSMAPosition == "LONG"
    currentSMAHigh := math.max(currentSMAHigh, high)
    currentSMALow := math.min(currentSMALow, low)
    if showSMABgBox and not na(currentSMABox)
        box.set_right(currentSMABox, bar_index)
        box.set_top(currentSMABox, currentSMAHigh)
        box.set_bottom(currentSMABox, currentSMALow)
    if showSMAAvgBgBox and not na(currentSMAAvgBox)
        box.set_right(currentSMAAvgBox, bar_index)

// --- Average Logic ---
// Track how far the price has fallen from the original buy price
fallPercent = currentSMAPosition == "LONG" and not na(buyPrice) ? ((buyPrice - low) / buyPrice) * 100 : 0.0
// We want to average every 10% drop (e.g., 10%, 20%, 30%, etc.)
currentAvgLevel = math.floor(fallPercent / 10)

// If we crossed a new 10% threshold, trigger an average signal
avgSignalCondition = currentSMAPosition == "LONG" and currentAvgLevel > lastAvgLevel and currentAvgLevel >= 1

if showSMA and avgSignalCondition
    lastAvgLevel := currentAvgLevel
    if showSMAAvgBgBox
        currentSMAAvgBox := box.new(left=bar_index, top=buyPrice, right=bar_index, bottom=low, bgcolor=smaAvgBgBoxColor, border_color=na)
    alert("SMA Average Signal Triggered!", alert.freq_once_per_bar_close)
    exactAvgPriceTarget = buyPrice * (1.0 - (currentAvgLevel * 0.10))
    labelAvgText = str.format("Avg {0}%\n{1}", str.tostring(currentAvgLevel * 10), str.tostring(exactAvgPriceTarget, "#.##"))
    label.new(x=bar_index, y=low - (low * 0.01), text=labelAvgText, style=label.style_label_up, color=color.rgb(139, 105, 41), textcolor=color.white)

// --- SMA Sell Condition ---
// 1. Original Rules: 200 is at bottom, 50 is in middle, 20 is at top AND price closes above 20
smaSellAlignmentTrue = (sma20 > sma50) and (sma50 > sma200) and (close > sma20)
smaSellAlignmentJustCrossed = smaSellAlignmentTrue and not smaSellAlignmentTrue[1]
// We enter on the Open of the very next candle after the crossover candle, IF we are currently long
smaSellCondition = smaSellAlignmentJustCrossed[1] and currentSMAPosition == "LONG"

if showSMA and smaSellCondition
    heldDays = not na(buyTime) ? math.floor((time - buyTime) / 86400000) : 0
    tradeGain = not na(buyPrice) ? ((open - buyPrice) / buyPrice) * 100 : 0.0
    currentSMAPosition := "NONE" // Reset to NONE
    buyPrice := na
    buyTime := na
    lastAvgLevel := 0
    alert("SMA Align Sell Signal Triggered!", alert.freq_once_per_bar_close)
    
    labelBaseText = str.format("SMA Sell\n{0}", str.tostring(open, "#.##"))
    labelDaysText = showSMASellDays ? str.format("\nDays: {0}", str.tostring(heldDays)) : ""
    labelGainText = showSMASellGain ? str.format("\nGain: {0}%", str.tostring(tradeGain, "#.##")) : ""
    
    labelSellText = labelBaseText + labelDaysText + labelGainText
    label.new(x=bar_index, y=high, text=labelSellText, style=label.style_label_down, color=color.rgb(180, 48, 48), textcolor=color.white)

// --- Envelope Strategy Logic & Plotting ---
envBasis = envExponential ? ta.ema(close, envLen) : ta.sma(close, envLen)
envK = envPercent / 100.0
envUpper = envBasis * (1 + envK)
envLower = envBasis * (1 - envK)

plot(showEnv ? envBasis : na, "Envelope Basis", color=envBasisColor)
envU = plot(showEnv ? envUpper : na, "Envelope Upper", color=envBandColor)
envL = plot(showEnv ? envLower : na, "Envelope Lower", color=envBandColor)
fill(envU, envL, color=showEnv ? envBgColor : na, title="Envelope Background")
